APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8099
DEBUG=false

POSTGRES_HOST=localhost
POSTGRES_PORT=5499
POSTGRES_DB=edo_adapter
POSTGRES_USER=edo
POSTGRES_PASSWORD=edo

REDIS_HOST=localhost
REDIS_PORT=6399
REDIS_PASSWORD=change-me

PASETO_SECRET_KEY=replace-with-32-byte-secret-xxxx
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4399
OTEL_SERVICE_NAME=edo-adapter-api

ENABLE_LOG_MASKING=true
CORS_ALLOW_ORIGINS=http://localhost:3099,http://localhost:8099

DEFAULT_RETRY_MAX_ATTEMPTS=5
DEFAULT_RETRY_BASE_SECONDS=10
DEFAULT_RETRY_MAX_SECONDS=900
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_TIMEOUT_SECONDS=60
CIRCUIT_HALF_OPEN_MAX_CALLS=2

PROVIDER_REQUEST_TIMEOUT_SECONDS=30
PROVIDER_CONNECT_TIMEOUT_SECONDS=5
WEBHOOK_DEDUP_TTL_SECONDS=86400
IDEMPOTENCY_KEY_TTL_SECONDS=604800
